          "ui_widget": "summary_value",
          "poll_interval_ms": 1000
        }
      }
    },
    "commands": {
      "standard_device_timeouts": {
        "default_timeout_ms": 5000,
        "items": [
          {
            "name": "start_device",
            "timeout_ms": 90000
          },
          {
            "name": "init_device",
            "timeout_ms": 30000
          },
          {
            "name": "release_device",
            "timeout_ms": 10000
          },
          {
            "name": "stop_device",
            "timeout_ms": 10000
          },
          {
            "name": "estop",
            "timeout_ms": 10000
          }
        ]
      }
    },
    "ui_bindings": {
      "standard_recording_status": {
        "record_timer": {
          "signal": "record_timer",
          "field": "duration_ns",
          "scale": 1e-09
        },
        "time_delay": {
          "signal": "time_delay",
          "field": "time_delay_ns",
          "scale": 1e-06
        }
      }
    },
    "error_messages": {
      "standard_device_errors": {
        "INIT_DEVICE_FAILED": {
          "title": "${agent_name} 状态异常",
          "message": "设备可能已经过热，或在软件启动前已经处于运行状态，请断开设备，待显示DISCONNECTED后，再插上设备。"
        }
      }
    },
    "topic_sets": {
      "standard_sensor_topics": [
        {
          "name": "imu_data",
          "encoding": "json",
          "parse_mode": "type_vector6_fast",
          "ui_max_hz": 60
        },
        {
          "name": "record_timer",
          "encoding": "json",
          "ui_max_hz": 10
        },
        {
