          "encoding": "json",
          "ui_max_hz": 5
        },
        {
          "name": "node_cookie",
          "encoding": "json",
          "ui_max_hz": 5,
          "metadata": {
            "role": "host_cookie"
          }
        }
      ],
      "camera_sensor_topics": [
        {
          "name": "imu_data",
          "encoding": "json",
          "parse_mode": "type_vector6_fast",
          "ui_max_hz": 60
        },
        {
